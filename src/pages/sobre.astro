---
import Layout from '../layouts/Layout.astro';

const team = [
  { name: "João Ferreira", role: "Fundador & Organizador", initials: "JF", color: "#8B5CF6" },
  { name: "Ana Lima",      role: "Community Manager",      initials: "AL", color: "#06B6D4" },
  { name: "Pedro Costa",  role: "Dev Lead",                initials: "PC", color: "#8B5CF6" },
  { name: "Maria Souza",  role: "Events & Parcerias",      initials: "MS", color: "#06B6D4" },
];

const values = [
  { icon: "M13 10V3L4 14h7v7l9-11h-7z", title: "Inovação", desc: "Buscamos sempre o que há de mais moderno em tecnologia e metodologia." },
  { icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z", title: "Comunidade", desc: "Pessoas antes de código. Relações genuínas constroem o ecossistema." },
  { icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253", title: "Educação", desc: "Democratizar o conhecimento técnico para toda a região do Litoral Norte." },
  { icon: "M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7", title: "Impacto Local", desc: "Focar no desenvolvimento do ecossistema digital de Igarassu e região." },
];
---

<Layout
  title="Sobre — GITA"
  description="Conheça a história, missão, valores e o time por trás do GITA — Grupo de Inovação e Tecnologia de Igarassu."
>
  {/* Hero */}
  <section class="relative pt-32 pb-24 overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 0%, rgba(139,92,246,0.18) 0%, transparent 60%), radial-gradient(ellipse at 80% 100%, rgba(6,182,212,0.12) 0%, transparent 50%);"></div>
    <div class="container mx-auto px-6 relative z-10 max-w-4xl">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium text-white mb-6 border border-white/10" style="background: rgba(255,255,255,0.05);">
        <span class="w-2 h-2 rounded-full bg-violet animate-pulse"></span>
        Quem Somos
      </div>
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold text-white mb-8 leading-tight">
        Nascemos em<br/>
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #8B5CF6, #06B6D4);">Igarassu</span>,<br/>
        crescemos juntos.
      </h1>
      <p class="text-muted text-xl leading-relaxed max-w-2xl">
        O GITA é uma comunidade independente que une desenvolvedores, designers, empreendedores e curiosos da tecnologia no Litoral Norte de Pernambuco. Acreditamos que grandes coisas acontecem quando pessoas talentosas se encontram.
      </p>
    </div>
  </section>

  {/* Stats bar */}
  <section class="py-12 border-y" style="border-color: rgba(255,255,255,0.07); background: rgba(255,255,255,0.02);">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center max-w-3xl mx-auto">
        {[
          { n: "2022", label: "Ano de fundação" },
          { n: "100+", label: "Membros ativos" },
          { n: "20+", label: "Eventos realizados" },
          { n: "15+", label: "Parceiros locais" },
        ].map(s => (
          <div>
            <div class="text-3xl font-black mb-1 text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #8B5CF6, #06B6D4);">{s.n}</div>
            <div class="text-muted text-sm">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Mission */}
  <section class="py-24">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-4xl font-bold text-white mb-6">Nossa Missão</h2>
          <p class="text-muted text-lg leading-relaxed mb-4">
            Criar e sustentar um espaço onde profissionais de tecnologia e negócios se conectam, aprendem e colaboram — construindo juntos o ecossistema digital do Litoral Norte de Pernambuco.
          </p>
          <p class="text-muted text-lg leading-relaxed">
            Acreditamos que o interior do Brasil tem todo o potencial para gerar startups, carreiras e soluções que impactam a vida real das pessoas da nossa região.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {values.map(v => (
            <div class="rounded-2xl p-5 border transition-all duration-300 hover:-translate-y-1 hover:border-violet/30"
              style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08);">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3" style="background: rgba(139,92,246,0.15);">
                <svg class="w-5 h-5" fill="none" stroke="#8B5CF6" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={v.icon}/>
                </svg>
              </div>
              <div class="text-white font-semibold text-sm mb-1">{v.title}</div>
              <div class="text-muted text-xs leading-relaxed">{v.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Team */}
  <section class="py-20 border-t" style="border-color: rgba(255,255,255,0.06);">
    <div class="container mx-auto px-6 max-w-4xl text-center">
      <h2 class="text-4xl font-bold text-white mb-4">O Time</h2>
      <p class="text-muted mb-14">As pessoas que fazem acontecer.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {team.map(m => (
          <div class="group flex flex-col items-center gap-3 cursor-default">
            <div class="relative w-16 h-16 rounded-2xl flex items-center justify-center text-white font-bold text-xl transition-all duration-300 group-hover:scale-110 group-hover:rotate-3"
              style={`background: linear-gradient(135deg, ${m.color}, ${m.color}99); box-shadow: 0 0 24px ${m.color}40;`}>
              {m.initials}
            </div>
            <div>
              <div class="text-white font-semibold text-sm">{m.name}</div>
              <div class="text-muted text-xs">{m.role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Contact anchor */}
  <section id="contato" class="py-20 text-center border-t" style="border-color: rgba(255,255,255,0.06);">
    <div class="container mx-auto px-6">
      <h2 class="text-3xl font-bold text-white mb-4">Entre em contato</h2>
      <p class="text-muted mb-8 max-w-xl mx-auto">Quer propor um evento, parceria ou apenas dizer oi? Manda mensagem.</p>
      <a href="mailto:oi@gita.dev" class="inline-flex items-center gap-2 px-8 py-4 font-semibold text-white rounded-full transition-all duration-300 hover:-translate-y-1"
        style="background: linear-gradient(135deg, #8B5CF6, #06B6D4); box-shadow: 0 0 30px rgba(139,92,246,0.35);">
        oi@gita.dev
      </a>
    </div>
  </section>
</Layout>
