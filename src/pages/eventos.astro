---
import Layout from '../layouts/Layout.astro';

const upcoming = [
  {
    date: "15",
    month: "ABR",
    year: "2025",
    title: "Inteligência Artificial no Mercado Local",
    type: "Palestra",
    speaker: "Dr. Lucas Mendes",
    location: "Hub Igarassu · Sala 02",
    spots: 40,
    spotsLeft: 12,
    accent: "#8B5CF6",
    accentBg: "rgba(139,92,246,0.12)",
    accentBorder: "rgba(139,92,246,0.3)",
    tagColor: "#C4B5FD",
  },
  {
    date: "28",
    month: "ABR",
    year: "2025",
    title: "Hackathon: Soluções para Igarassu",
    type: "Hackathon",
    speaker: "Equipes de até 4 pessoas",
    location: "IFPE · Igarassu",
    spots: 80,
    spotsLeft: 35,
    accent: "#06B6D4",
    accentBg: "rgba(6,182,212,0.12)",
    accentBorder: "rgba(6,182,212,0.3)",
    tagColor: "#67E8F9",
  },
  {
    date: "10",
    month: "MAI",
    year: "2025",
    title: "Mesa Redonda: Startups no Interior de PE",
    type: "Mesa Redonda",
    speaker: "Painel com 5 empreendedores",
    location: "Online · Google Meet",
    spots: 30,
    spotsLeft: 8,
    accent: "#8B5CF6",
    accentBg: "rgba(139,92,246,0.12)",
    accentBorder: "rgba(139,92,246,0.3)",
    tagColor: "#C4B5FD",
  },
];

const past = [
  { month: "MAR 2025", title: "Workshop de React + Next.js",              type: "Workshop",     attendees: 38 },
  { month: "FEV 2025", title: "Rinha de Código #03 — Algoritmos",         type: "Rinha",        attendees: 24 },
  { month: "JAN 2025", title: "Encontro de Início de Ano GITA",           type: "Encontro",     attendees: 55 },
  { month: "DEZ 2024", title: "Demo Day — Projetos da Comunidade",        type: "Demo Day",     attendees: 70 },
  { month: "NOV 2024", title: "Palestra: Carreira em Tech no Interior",   type: "Palestra",     attendees: 44 },
  { month: "OUT 2024", title: "Rinha de Código #02 — SQL Battles",        type: "Rinha",        attendees: 20 },
];

const typeIcon: Record<string, string> = {
  Palestra:     "M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z",
  Hackathon:    "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  "Mesa Redonda": "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  Workshop:     "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  Rinha:        "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  Encontro:     "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
  "Demo Day":   "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
};
---

<Layout
  title="Eventos — GITA"
  description="Calendário de eventos do GITA: palestras, hackathons, mesas redondas e rinhas de código em Igarassu."
>

  {/* ── HERO ── */}
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 60% 0%, rgba(139,92,246,0.15) 0%, transparent 55%), radial-gradient(ellipse at 5% 80%, rgba(6,182,212,0.1) 0%, transparent 50%);"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 48px 48px;"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10 text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium text-white mb-6 border border-white/10"
        style="background: rgba(255,255,255,0.05);">
        <span class="w-2 h-2 rounded-full bg-cyan animate-pulse"></span>
        Calendário de Eventos
      </div>

      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold text-white mb-6 leading-[1.08]">
        Onde acontece<br/>
        a <span class="text-transparent bg-clip-text font-black"
          style="background-image: linear-gradient(135deg, #8B5CF6, #06B6D4);">inovação</span>
      </h1>

      <p class="text-muted text-xl leading-relaxed">
        Palestras, hackathons, mesas redondas e muito mais.<br/>
        Junte-se a nós e faça parte da transformação digital de Igarassu.
      </p>
    </div>
  </section>

  {/* ── PRÓXIMOS EVENTOS ── */}
  <section class="pb-24">
    <div class="container mx-auto px-6 max-w-4xl">

      <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
        <span class="w-1 h-7 rounded-full flex-shrink-0"
          style="background: linear-gradient(#8B5CF6, #06B6D4);"></span>
        Próximos Eventos
      </h2>

      <div class="flex flex-col gap-4">
        {upcoming.map(ev => {
          const pct = Math.round(((ev.spots - ev.spotsLeft) / ev.spots) * 100);
          const icon = typeIcon[ev.type] ?? typeIcon["Palestra"];
          return (
            <div class="group rounded-2xl border overflow-hidden transition-all duration-400 hover:-translate-y-0.5"
              style={`background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.09);`}>

              {/* Colored top accent */}
              <div class="h-0.5 w-full transition-opacity duration-500 opacity-0 group-hover:opacity-100"
                style={`background: linear-gradient(90deg, ${ev.accent}, ${ev.accent === '#8B5CF6' ? '#06B6D4' : '#8B5CF6'});`}></div>

              <div class="p-6 flex flex-col sm:flex-row sm:items-center gap-5">

                {/* Date block */}
                <div class="flex-shrink-0 w-20 rounded-xl py-3 text-center border"
                  style={`background: ${ev.accentBg}; border-color: ${ev.accentBorder};`}>
                  <div class="text-xs font-bold uppercase tracking-widest mb-0.5"
                    style={`color: ${ev.tagColor};`}>{ev.month}</div>
                  <div class="text-3xl font-black text-white leading-none">{ev.date}</div>
                  <div class="text-xs mt-0.5" style="color: rgba(148,163,184,0.6);">{ev.year}</div>
                </div>

                {/* Info */}
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full"
                      style={`background: ${ev.accentBg}; color: ${ev.tagColor}; border: 1px solid ${ev.accentBorder};`}>
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon}/>
                      </svg>
                      {ev.type}
                    </span>
                  </div>
                  <h3 class="text-white font-bold text-lg leading-snug mb-2">{ev.title}</h3>
                  <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted">
                    <span class="flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                      </svg>
                      {ev.speaker}
                    </span>
                    <span class="flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      {ev.location}
                    </span>
                  </div>
                </div>

                {/* Spots + CTA */}
                <div class="flex-shrink-0 flex flex-col sm:items-end gap-3">
                  <div>
                    <div class="flex items-center justify-between gap-4 mb-1.5">
                      <span class="text-xs text-muted">{ev.spots - ev.spotsLeft}/{ev.spots} inscritos</span>
                      <span class="text-xs font-semibold" style={`color: ${ev.tagColor};`}>{ev.spotsLeft} vagas</span>
                    </div>
                    <div class="w-40 h-1.5 rounded-full overflow-hidden"
                      style="background: rgba(255,255,255,0.08);">
                      <div class="h-full rounded-full transition-all duration-700"
                        style={`width: ${pct}%; background: linear-gradient(90deg, ${ev.accent}, ${ev.accent === '#8B5CF6' ? '#06B6D4' : '#8B5CF6'});`}></div>
                    </div>
                  </div>
                  <a href="#"
                    class="inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-semibold text-white rounded-xl transition-all duration-300 hover:opacity-90 hover:-translate-y-0.5 whitespace-nowrap"
                    style={`background: ${ev.accent}; box-shadow: 0 0 16px ${ev.accent}60;`}>
                    Inscrever-se
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* ── EVENTOS ANTERIORES ── */}
  <section class="py-20 border-t" style="border-color: rgba(255,255,255,0.06); background: rgba(255,255,255,0.02);">
    <div class="container mx-auto px-6 max-w-4xl">

      <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
        <span class="w-1 h-7 rounded-full flex-shrink-0"
          style="background: rgba(255,255,255,0.2);"></span>
        Eventos Anteriores
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {past.map(ev => {
          const icon = typeIcon[ev.type] ?? typeIcon["Palestra"];
          return (
            <div class="group rounded-xl p-5 border transition-all duration-300 hover:border-white/20 hover:-translate-y-0.5 cursor-default"
              style="background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.07);">
              <div class="text-xs font-semibold uppercase tracking-widest text-muted/50 mb-3">{ev.month}</div>
              <div class="flex items-start gap-3 mb-4">
                <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5"
                  style="background: rgba(255,255,255,0.06);">
                  <svg class="w-4 h-4 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon}/>
                  </svg>
                </div>
                <p class="text-white font-medium text-sm leading-snug">{ev.title}</p>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-xs text-muted/50 rounded-full px-2.5 py-0.5 border"
                  style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08);">
                  {ev.type}
                </span>
                <span class="text-xs text-muted flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  {ev.attendees}
                </span>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* ── CTA ── */}
  <section class="py-20 text-center">
    <div class="container mx-auto px-6 max-w-xl">
      <h3 class="text-2xl font-bold text-white mb-3">Quer propor um evento?</h3>
      <p class="text-muted mb-8">Palestras, workshops, mesas redondas — a comunidade está aberta a ideias de todos.</p>
      <a href="/sobre#contato"
        class="inline-flex items-center gap-2 px-8 py-4 font-semibold text-white rounded-full transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl"
        style="background: linear-gradient(135deg, #8B5CF6, #7C3AED); box-shadow: 0 0 28px rgba(139,92,246,0.35);">
        Fale com a gente
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

</Layout>
