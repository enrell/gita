---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Comunidade — GITA"
  description="Junte-se à comunidade GITA — desenvolvedores e empreendedores do Litoral Norte de Pernambuco."
>
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 30%, rgba(139,92,246,0.2) 0%, transparent 60%), radial-gradient(ellipse at 80% 80%, rgba(6,182,212,0.12) 0%, transparent 50%);"></div>

    <div class="container mx-auto px-6 relative z-10 text-center max-w-3xl py-24">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium text-white mb-6 border border-white/10" style="background: rgba(255,255,255,0.05);">
        <span class="w-2 h-2 rounded-full bg-violet animate-pulse"></span>
        Faça Parte
      </div>
      <h1 class="text-5xl sm:text-6xl font-extrabold text-white mb-6 leading-tight">
        Entre para a<br/>
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #8B5CF6, #06B6D4);">Comunidade</span>
      </h1>
      <p class="text-muted text-xl mb-12 leading-relaxed">
        Junte-se a mais de 100 desenvolvedores, designers e empreendedores que estão construindo o futuro digital de Igarassu.
      </p>

      {/* Quick join form */}
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-10">
        <input
          type="email"
          placeholder="seu@email.com"
          class="flex-1 px-5 py-3.5 rounded-full text-sm text-white placeholder-muted/50 border border-white/15 outline-none focus:border-violet/60 transition-colors duration-200"
          style="background: rgba(255,255,255,0.06);"
        />
        <button type="submit"
          class="px-7 py-3.5 font-semibold text-white text-sm rounded-full transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg flex-shrink-0"
          style="background: linear-gradient(135deg, #8B5CF6, #7C3AED); box-shadow: 0 0 24px rgba(139,92,246,0.35);">
          Participar
        </button>
      </form>

      <div class="flex items-center justify-center gap-6 text-sm text-muted flex-wrap">
        <span class="flex items-center gap-1.5">✓ Gratuito</span>
        <span class="flex items-center gap-1.5">✓ Sem spam</span>
        <span class="flex items-center gap-1.5">✓ Saia quando quiser</span>
      </div>
    </div>
  </section>
</Layout>
