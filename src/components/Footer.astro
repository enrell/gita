---

<section id="depoimentos" class="py-24 bg-off-white overflow-hidden">
  <div class="container mx-auto px-6">
    {/* Partners */}
    <div class="text-center mb-20">
      <div data-animate="fade-up" class="inline-flex items-center gap-2 px-4 py-2 bg-violet/10 rounded-full text-deep-navy font-medium text-sm mb-4 border border-violet/20">
        <span class="w-2 h-2 bg-cyan rounded-full"></span>
        Quem Confia
      </div>
      <h2 data-animate="fade-up" data-delay="200" class="text-3xl sm:text-4xl md:text-5xl font-bold text-deep-navy mb-4">
        Empresas e Instituições Parceiras
      </h2>
      <p data-animate="fade-up" data-delay="400" class="text-slate max-w-xl mx-auto">
        Juntos construindo o ecossistema de tecnologia de Igarassu
      </p>

      <div data-animate="fade-up" data-delay="600" data-stagger="100" class="flex flex-wrap justify-center items-center gap-8 md:gap-12 mt-12">
        {['Parceiro 1', 'Parceiro 2', 'Parceiro 3', 'Parceiro 4'].map((partner) => (
          <div data-stagger-item class="group w-32 h-16 bg-white rounded-xl flex items-center justify-center text-slate/40 text-sm font-medium shadow-sm hover:shadow-lg hover:shadow-violet/10 hover:scale-110 transition-all duration-500 cursor-pointer border border-transparent hover:border-violet/20">
            <span class="group-hover:text-deep-navy transition-colors duration-300">{partner}</span>
          </div>
        ))}
      </div>
    </div>

    {/* Testimonials */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-20">
      {testimonials.map((item, i) => (
        <div
          data-animate={i === 0 ? "slide-left" : "slide-right"}
          data-delay={`${800 + i * 200}`}
          class="group relative bg-white rounded-3xl p-8 shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 border border-slate/10 overflow-hidden"
        >
          <div class="absolute -right-10 -top-10 w-40 h-40 bg-gradient-to-br from-violet/10 to-transparent rounded-full group-hover:scale-150 transition-transform duration-700"></div>

          <div class="relative mb-6">
            <svg class="w-10 h-10 text-violet/20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
          </div>

          <p class="relative text-slate/80 text-lg leading-relaxed mb-6 group-hover:text-slate transition-colors duration-300">
            "{item.quote}"
          </p>

          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-violet to-violet-600 flex items-center justify-center text-white font-bold group-hover:scale-110 transition-transform duration-300 shadow-lg">
              {item.author.charAt(0)}
            </div>
            <div>
              <div class="font-semibold text-deep-navy">{item.author}</div>
              <div class="text-sm text-slate/60">{item.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

{/* Final CTA */}
<footer id="comunidade" class="bg-deep-navy relative overflow-hidden">
  {/* Animated background */}
  <div class="absolute inset-0 opacity-30">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,.1) 1px, transparent 0); background-size: 60px 60px;"></div>
    <div class="absolute top-1/3 left-1/4 w-64 h-64 bg-violet/10 rounded-full blur-3xl animate-pulse" style="animation-duration: 7s;"></div>
    <div class="absolute bottom-1/3 right-1/4 w-48 h-48 bg-cyan/10 rounded-full blur-3xl animate-pulse" style="animation-duration: 9s; animation-delay: 1s;"></div>
  </div>

  <div class="relative z-10 py-24 px-6">
    <div class="text-center max-w-4xl mx-auto">
      <div data-animate="fade-up" class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 backdrop-blur-sm rounded-full text-white font-medium text-sm mb-8 border border-white/10">
        <span class="w-2 h-2 bg-violet rounded-full animate-pulse"></span>
        Faça Parte
      </div>

      <h2 data-animate="fade-up" data-delay="200" class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-8 leading-tight">
        O futuro da tecnologia em <br class="hidden sm:block"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet to-cyan">Igarassu</span> está sendo construído <span class="text-cyan">agora</span>.
      </h2>

      <p data-animate="fade-up" data-delay="400" class="text-xl sm:text-2xl text-slate mb-12">
        Venha construir com a gente.
      </p>

      <div data-animate="scale-up" data-delay="600" class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-20">
        <a
          href="#"
          class="group relative inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-violet to-violet-600 text-white font-semibold rounded-full overflow-hidden transition-all duration-500 hover:shadow-2xl hover:shadow-violet/40 hover:-translate-y-2"
        >
          <span class="relative z-10">Entrar na Comunidade</span>
          <svg class="w-5 h-5 relative z-10 transition-transform duration-300 group-hover:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
          <div class="absolute inset-0 bg-gradient-to-r from-cyan to-violet opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </a>

        <a
          href="#"
          class="group inline-flex items-center gap-3 px-10 py-5 text-white font-medium rounded-full border-2 border-white/20 hover:bg-white/5 hover:border-white/40 transition-all duration-300 hover:-translate-y-1"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span>Contato por Email</span>
        </a>
      </div>
    </div>
  </div>

  {/* Footer Links */}
  <div class="relative z-10 border-t border-white/10">
    <div class="container mx-auto px-6 py-12">
      <div class="flex flex-col md:flex-row justify-between items-center gap-8">
        <div data-animate="fade-in" class="flex items-center gap-3 group">
          <div class="w-12 h-12 bg-gradient-to-br from-violet to-violet-600 rounded-xl flex items-center justify-center shadow-lg shadow-violet/30 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300">
            <span class="text-white font-bold text-xl">G</span>
          </div>
          <div>
            <div class="text-white font-bold text-xl">GITA</div>
            <div class="text-slate text-sm">Grupo de Inovação e Tecnologia</div>
          </div>
        </div>

        <div data-animate="fade-in" data-delay="200" class="flex items-center gap-3">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              class="group w-11 h-11 rounded-full bg-white/10 flex items-center justify-center text-slate hover:bg-gradient-to-br hover:from-violet hover:to-violet-600 hover:text-white transition-all duration-300 hover:scale-110 hover:-translate-y-1 shadow-lg hover:shadow-violet/30"
              aria-label={social.name}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.icon}/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <div data-animate="fade-in" data-delay="400" class="mt-12 pt-8 border-t border-white/10">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-slate/60 text-sm">
            © {new Date().getFullYear()} GITA. Todos os direitos reservados.
          </p>
          <div class="flex items-center gap-6 text-sm text-slate/60">
            <a href="#" class="hover:text-white transition-colors duration-300">Privacidade</a>
            <a href="#" class="hover:text-white transition-colors duration-300">Termos</a>
            <a href="#" class="hover:text-white transition-colors duration-300">Contato</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
