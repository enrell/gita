  {
    quote: "A comunidade acelerou meu projeto de forma que eu não imaginava. O networking vale ouro.",
    author: "João Silva",
    role: "Desenvolvedor Frontend"
  },
  {
    quote: "Encontrei meu sócio técnico aqui. Hoje nossa startup cresce 20% ao mês.",
    author: "Maria Santos",
    role: "Empreendedora"
  }
