---
const events = [
  {
    title: "Palestras Mensais",
    description: "Especialistas compartilham conhecimento sobre stacks modernas, carreira e empreendedorismo.",
    icon: "M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z",
    color: "violet",
    gradient: "from-violet to-violet-600"
  },
  {
    title: "Hackathons",
    description: "Maratonas de programação para resolver desafios reais e criar soluções inovadoras em equipe.",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
    color: "cyan",
    gradient: "from-cyan to-cyan-600"
  },
  {
    title: "Mesas Redondas",
    description: "Discussões abertas sobre tendências tecnológicas e oportunidades do mercado local.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
    color: "deep-navy",
    gradient: "from-deep-navy to-slate"
  }
];
---

<section id="eventos" class="py-24 bg-deep-navy relative overflow-hidden">
  {/* Animated background */}
  <div class="absolute inset-0">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,.05) 1px, transparent 0); background-size: 50px 50px;"></div>
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-violet/10 rounded-full blur-[120px] animate-pulse" style="animation-duration: 6s;"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-cyan/10 rounded-full blur-[100px] animate-pulse" style="animation-duration: 8s; animation-delay: 1s;"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    {/* Section Header */}
    <div class="text-center mb-20">
      <div data-animate="fade-up" class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 backdrop-blur-sm rounded-full text-white font-medium text-sm mb-6 border border-white/10">
        <span class="w-2 h-2 bg-cyan rounded-full animate-pulse"></span>
        Eventos
      </div>
      <h2 data-animate="fade-up" data-delay="200" class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-6">
        Como Acontece?
      </h2>
      <p data-animate="fade-up" data-delay="400" class="text-slate max-w-2xl mx-auto text-lg sm:text-xl leading-relaxed">
        Uma variedade de formatos para conectar, aprender e construir juntos.
      </p>
    </div>

    {/* Events Grid */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {events.map((event, index) => (
        <div
          data-animate={index === 0 ? "slide-left" : index === 1 ? "fade-up" : "slide-right"}
          data-delay={`${600 + index * 200}`}
          class="group relative h-full"
        >
          {/* Card Container */}
          <div class="relative h-full bg-gradient-to-b from-white/15 to-white/5 backdrop-blur-md rounded-2xl p-8 border border-white/20 hover:border-white/40 transition-all duration-500 hover:-translate-y-2 overflow-hidden shadow-xl shadow-black/20">
            {/* Glow Effect */}
            <div class={`absolute -inset-px bg-gradient-to-b ${event.gradient} opacity-0 group-hover:opacity-30 blur-2xl transition-opacity duration-500 rounded-2xl`}></div>

            {/* Shine Effect */}
            <div class="absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            {/* Top Line Accent */}
            <div class={`absolute top-0 left-8 right-8 h-1 bg-gradient-to-r ${event.gradient} rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>

            <div class="relative flex flex-col h-full">
              {/* Icon Container */}
              <div class={`relative w-14 h-14 rounded-xl bg-gradient-to-br ${event.gradient} flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 shadow-lg`}>
                {/* Icon Glow */}
                <div class={`absolute inset-0 bg-gradient-to-br ${event.gradient} blur-lg opacity-50 group-hover:opacity-80 transition-opacity duration-500`}></div>
                <svg class="relative w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={event.icon} />
                </svg>
              </div>

              {/* Content */}
              <h3 class="text-xl font-bold text-white mb-3 group-hover:text-cyan transition-colors duration-300">
                {event.title}
              </h3>

              <p class="text-slate/80 text-sm leading-relaxed mb-6 flex-grow">
                {event.description}
              </p>

              {/* Bottom Link */}
              <div class="flex items-center gap-2 text-cyan/70 group-hover:text-cyan transition-colors duration-300 pt-4 border-t border-white/10">
                <span class="text-sm font-medium">Saiba mais</span>
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Timeline */}
    <div data-animate="fade-up" data-delay="1200" class="mt-20 max-w-4xl mx-auto">
      <div class="flex items-center justify-between relative">
        <div class="absolute top-1/2 left-0 right-0 h-0.5 bg-gradient-to-r from-violet via-cyan to-violet rounded-full"></div>
        {["Ideia", "Validação", "Execução", "Lançamento"].map((step, i) => (
          <div class="relative z-10 flex flex-col items-center group">
            <div class={`w-4 h-4 rounded-full ${i === 0 ? 'bg-violet' : 'bg-white'} group-hover:scale-150 transition-transform duration-300 border-4 border-deep-navy`}></div>
            <span class="mt-3 text-sm text-slate group-hover:text-white transition-colors duration-300">{step}</span>
          </div>
        ))}
      </div>
    </div>

    {/* CTA */}
    <div data-animate="scale-up" data-delay="1400" class="text-center mt-16">
      <a
        href="#comunidade"
        class="group relative inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-violet to-violet-600 text-white font-semibold rounded-full overflow-hidden transition-all duration-500 hover:shadow-2xl hover:shadow-violet/40 hover:-translate-y-2"
      >
        <span class="relative z-10">Participe do próximo evento</span>
        <svg class="w-5 h-5 relative z-10 transition-transform duration-300 group-hover:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
        <div class="absolute inset-0 bg-gradient-to-r from-violet-600 to-violet-700 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      </a>
    </div>
  </div>
</section>
