---
---

<section id="sobre" class="py-24 bg-off-white overflow-hidden">
  <div class="container mx-auto px-6">
    {/* Section Header */}
    <div data-animate="fade-up" class="text-center mb-20">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-violet/10 rounded-full text-deep-navy font-medium text-sm mb-4 border border-violet/20">
        <span class="w-2 h-2 bg-violet rounded-full"></span>
        Quem Somos
      </span>
      <h2 data-animate="fade-up" data-delay="200" class="text-4xl sm:text-5xl md:text-6xl font-bold text-deep-navy mb-6">
        Para Quem é o GITA?
      </h2>
      <p data-animate="fade-up" data-delay="400" class="text-cadet max-w-2xl mx-auto text-lg sm:text-xl leading-relaxed">
        Nossa comunidade é feita para quem quer transformar ideias em realidade.
        <span class="text-violet font-medium">Tecnologia</span> + <span class="text-cyan font-medium">Negócios</span> = <span class="font-medium text-deep-navy">Inovação</span>
      </p>
    </div>

    {/* Bento Grid */}
    <div data-animate="fade-up" data-delay="600" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">

      {/* Para Desenvolvedores */}
      <div data-animate="slide-left" data-delay="300" class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-2 border border-slate/10 hover:border-violet/20">
        <div class="w-14 h-14 rounded-xl bg-violet/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
          </svg>
        </div>

        <h3 class="text-2xl font-bold text-deep-navy mb-3">Para Desenvolvedores</h3>
        <p class="text-cadet mb-6 leading-relaxed">Evolua tecnicamente, troque experiências de stack, encontre mentorias e descubra oportunidades de trabalho no mercado local.</p>

        <div class="space-y-3">
          {["Troca de stack", "Mentorias", "Networking técnico", "Oportunidades locais"].map((feature) => (
            <div class="flex items-center gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-violet"></div>
              <span class="text-sm text-cadet">{feature}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Para Empreendedores */}
      <div data-animate="slide-right" data-delay="500" class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-2 border border-slate/10 hover:border-cyan/20">
        <div class="w-14 h-14 rounded-xl bg-cyan/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
        </div>

        <h3 class="text-2xl font-bold text-deep-navy mb-3">Para Empreendedores</h3>
        <p class="text-cadet mb-6 leading-relaxed">Encontre talentos locais, valide suas ideias e construa conexões estratégicas para impulsionar seu negócio.</p>

        <div class="space-y-3">
          {["Encontre talentos", "Valide ideias", "Networking", "Parcerias estratégicas"].map((feature) => (
            <div class="flex items-center gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-cyan"></div>
              <span class="text-sm text-cadet">{feature}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Small Cards */}
      <div class="col-span-1 md:col-span-2 lg:col-span-1 flex flex-col gap-6">

        {/* Eventos Mensais */}
        <div data-animate="scale-up" data-delay="700" class="group bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-1 border border-slate/10 flex-1">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet to-violet-600 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-lg font-bold text-deep-navy mb-1">Eventos Mensais</h4>
              <p class="text-cadet text-sm leading-relaxed">Palestras, workshops e discussões sobre tendências.</p>
            </div>
          </div>
        </div>

        {/* Comunidade */}
        <div data-animate="scale-up" data-delay="900" class="group bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-1 border border-slate/10 flex-1">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan to-cyan-600 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-lg font-bold text-deep-navy mb-1">Comunidade Vibrante</h4>
              <p class="text-cadet text-sm leading-relaxed">Crie, aprenda e cresça junto com outros apaixonados.</p>
            </div>
          </div>
        </div>

      </div>
    </div>

    {/* CTA */}
    <div data-animate="blur-in" data-delay="1000" class="mt-16 text-center">
      <p class="text-slate mb-6">Junte-se a mais de 100 desenvolvedores e empreendedores locais</p>
      <a href="#comunidade" class="group inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-violet to-violet-600 text-white font-semibold rounded-full hover:shadow-xl hover:shadow-violet/30 hover:-translate-y-1 transition-all duration-300">
        <span>Comece sua jornada</span>
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
