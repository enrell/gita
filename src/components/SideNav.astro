---
const navItems = [
  { id: "hero", label: "Início", color: "violet", hex: "#8B5CF6" },
  { id: "sobre", label: "Quem Somos", color: "cyan", hex: "#06B6D4" },
  { id: "eventos", label: "Eventos", color: "violet", hex: "#8B5CF6" },
  { id: "depoimentos", label: "Depoimentos", color: "cyan", hex: "#06B6D4" },
  { id: "comunidade", label: "Participe", color: "violet", hex: "#8B5CF6" }
];
---

{/* Área de trigger invisível no lado direito */}
<div id="nav-trigger-area" class="fixed top-0 right-0 w-[40vw] h-screen z-40 hidden lg:block"></div>

<nav
  id="side-nav"
  class="fixed right-6 top-[10vh] z-50 hidden lg:flex flex-col items-center h-[80vh] transition-all duration-300 pointer-events-none translate-x-4 opacity-0"
  data-mode="dark"
>
  {/* Container principal */}
  <div class="relative flex flex-col items-end justify-between flex-1 w-48 py-4 pointer-events-auto">
    {/* Linha de fundo (tracejada) */}
    <div class="line-bg absolute top-0 bottom-0 right-4 w-px bg-deep-navy/20 border-l border-dashed border-deep-navy/30 transition-colors duration-300"></div>

    {/* Ponto Viajante (Traveling Dot) */}
    <div
      id="traveling-dot"
      class="absolute top-0 right-0 w-8 flex items-center justify-center transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] pointer-events-none z-20"
      style="opacity: 0; transform: translateY(0px); height: 64px; --active-color: #8B5CF6;"
    >
      <span class="traveling-ring absolute w-8 h-8 rounded-full border-2 transition-colors duration-300" style="border-color: var(--active-color);"></span>
      <span class="traveling-glow w-3 h-3 rounded-full transition-colors duration-300" style="background-color: var(--active-color); box-shadow: 0 0 12px var(--active-color);"></span>
    </div>

    {/* Linha de progresso (preenchida) */}
    <div
      id="progress-line"
      class="absolute top-0 right-4 w-0.5 bg-gradient-to-b from-violet via-cyan to-violet rounded-full transition-all duration-300 origin-top"
      style="height: 0%;"
    ></div>

    {/* Pontos de navegação */}
    {navItems.map((item) => (
      <a
        href={`#${item.id}`}
        class="nav-item relative flex items-center justify-end group nav-item-wrapper w-full flex-1 cursor-pointer"
        data-nav-item={item.id}
        data-section={item.id}
        data-color={item.hex}
        aria-label={`Ir para ${item.label}`}
      >
        {/* Texto do Badge / Tooltip */}
        <span class="tooltip absolute right-8 mr-2 flex items-center opacity-0 translate-x-3 transition-all duration-200 ease-out z-10 pointer-events-auto">
          <span class="tooltip-bg bg-deep-navy/90 backdrop-blur-md text-white/90 text-xs font-semibold px-3 py-1.5 rounded-lg whitespace-nowrap shadow-xl border border-white/10 transition-all duration-300 group-hover:scale-105">
            {item.label}
          </span>
          <span class="tooltip-arrow flex-shrink-0 w-2 h-2 bg-deep-navy/90 rotate-45 border-r border-t border-white/10 -ml-1"></span>
        </span>

        {/* Empty dot para sessões inativas */}
        <span class="w-8 h-8 relative flex items-center justify-center pointer-events-none">
          <span class="nav-empty-dot w-2 h-2 rounded-full transition-all duration-300 pointer-events-none group-hover:scale-125"></span>
        </span>
      </a>
    ))}
  </div>

  {/* Indicador de scroll */}
  <div class="mt-8 flex flex-col items-center gap-2 pointer-events-auto">
    <span class="scroll-text text-deep-navy/40 text-[10px] font-medium uppercase tracking-widest rotate-90 origin-center mb-4 transition-colors duration-300">Scroll</span>
    <div class="scroll-indicator w-px h-8 bg-deep-navy/20 relative overflow-hidden transition-colors duration-300">
      <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-violet to-transparent animate-pulse transition-colors duration-300"></div>
    </div>
  </div>
</nav>

<style>
  /* Tooltip - aparece no hover */
  .nav-item-wrapper:hover .tooltip,
  .nav-visible .tooltip {
    opacity: 1 !important;
    transform: translateX(0) !important;
  }

  /* Hover das bolinhas vazias */
  .nav-empty-dot {
    background-color: rgba(15, 23, 42, 0.3);
  }
  .nav-item-wrapper:hover .nav-empty-dot,
  .nav-visible .nav-empty-dot {
    background-color: var(--item-color);
  }

  /* Tooltip hover effects */
  .nav-item-wrapper:hover {
    z-index: 10;
  }

  /* ESTADOS DO MODO ESCURO */
  [data-mode="dark"] .line-bg {
    border-color: rgba(255, 255, 255, 0.2) !important;
  }

  [data-mode="dark"] .line-bg::before {
    border-color: rgba(255, 255, 255, 0.15) !important;
  }

  [data-mode="dark"] .scroll-text {
    color: rgba(255, 255, 255, 0.5) !important;
  }

  [data-mode="dark"] .scroll-indicator {
    background-color: rgba(255, 255, 255, 0.2) !important;
  }

  [data-mode="dark"] .nav-empty-dot {
    background-color: rgba(255, 255, 255, 0.3) !important;
  }

  /* Modo escuro para tooltips */
  [data-mode="dark"] .tooltip-bg {
    background-color: rgba(255, 255, 255, 0.95) !important;
    color: #0f172a !important;
    border-color: rgba(255, 255, 255, 0.3) !important;
  }

  [data-mode="dark"] .tooltip-arrow {
    background-color: rgba(255, 255, 255, 0.95) !important;
  }

  /* Navegação visível (ativo pela área de trigger) */
  #side-nav.nav-visible {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }
</style>

<script>
  const initNav = () => {
    const sections = document.querySelectorAll('section[id], footer[id]');
    const navButtons = document.querySelectorAll('[data-section]');
    const progressLine = document.getElementById('progress-line');
    const sideNav = document.getElementById('side-nav');
    const triggerArea = document.getElementById('nav-trigger-area');
    const navItems = document.querySelectorAll('.nav-item-wrapper');

    let currentSection = '';
    let mouseInTriggerArea = false;

    // Seções com fundo escuro
    const darkSections = ['hero', 'eventos', 'comunidade'];

    // Configuração da área de trigger - AGORA 40% DO LADO DIREITO
    function checkTriggerArea(x: number) {
      const screenWidth = window.innerWidth;
      const triggerWidth = screenWidth * 0.4;
      return x >= screenWidth - triggerWidth;
    }

    // Mouse move para detectar entrada na área
    document.addEventListener('mousemove', (e) => {
      const wasInArea = mouseInTriggerArea;
      mouseInTriggerArea = checkTriggerArea(e.clientX);

      // Entrou na área
      if (mouseInTriggerArea && !wasInArea) {
        sideNav?.classList.add('nav-visible');
        navItems.forEach(item => item.classList.add('nav-visible'));
      }

      // Saiu da área
      if (!mouseInTriggerArea && wasInArea) {
        // Pequeno delay para não sumir imediatamente
        setTimeout(() => {
          if (!mouseInTriggerArea) {
            sideNav?.classList.remove('nav-visible');
            navItems.forEach(item => item.classList.remove('nav-visible'));
          }
        }, 100);
      }
    });

    // Também mostrar ao passar diretamente sobre a navegação
    sideNav?.addEventListener('mouseenter', () => {
      sideNav.classList.add('nav-visible');
    });

    sideNav?.addEventListener('mouseleave', () => {
      if (!mouseInTriggerArea) {
        sideNav.classList.remove('nav-visible');
      }
    });

    // Determina a seção mais visível na viewport
    function getMostVisibleSection() {
      const viewportHeight = window.innerHeight;
      let bestId = '';
      let bestVisible = 0;

      sections.forEach(section => {
        const rect = section.getBoundingClientRect();
        // Sobreposição entre o elemento e a viewport
        const visibleTop = Math.max(0, rect.top);
        const visibleBottom = Math.min(viewportHeight, rect.bottom);
        const visiblePx = Math.max(0, visibleBottom - visibleTop);

        if (visiblePx > bestVisible) {
          bestVisible = visiblePx;
          bestId = section.id;
        }
      });

      return bestId;
    }

    function updateFromScroll() {
      const id = getMostVisibleSection();
      if (id && id !== currentSection) {
        currentSection = id;
        updateActiveNav();
        updateProgressLine();
        updateNavMode(id);
      }
    }

    // Atualiza na inicialização, no scroll e no resize
    updateFromScroll();
    window.addEventListener('scroll', updateFromScroll, { passive: true });
    window.addEventListener('resize', () => {
      // Usar requestAnimationFrame garante que o layout já recalculou o offsetTop
      requestAnimationFrame(updateActiveNav);
    }, { passive: true });

    function updateActiveNav() {
      const travelingDot = document.getElementById('traveling-dot');
      
      navItems.forEach((item: Element) => {
        item.classList.remove('nav-item-active');
        const itemId = item.getAttribute('data-nav-item');
        
        if (itemId === currentSection) {
          item.classList.add('nav-item-active');
          
          if (travelingDot) {
            const el = item as HTMLElement;
            const topPos = el.offsetTop;
            const heightPos = el.offsetHeight;
            const itemColor = el.getAttribute('data-color') || '#8B5CF6';
            
            travelingDot.style.opacity = '1';
            travelingDot.style.height = `${heightPos}px`;
            travelingDot.style.transform = `translateY(${topPos}px)`;
            travelingDot.style.setProperty('--active-color', itemColor);
          }
        }
      });
    }

    function updateProgressLine() {
      const sectionIds = Array.from(sections).map(s => s.id);
      const currentIndex = sectionIds.indexOf(currentSection);

      if (currentIndex === -1 || !progressLine) {
        if (progressLine) progressLine.style.height = '0%';
        return;
      }

      const totalSections = sectionIds.length - 1;
      const progress = totalSections === 0 ? 0 : (currentIndex / totalSections) * 100;
      progressLine.style.height = `${progress}%`;
    }

    function updateNavMode(sectionId: string) {
      if (!sideNav) return;

      const isDark = darkSections.includes(sectionId);
      sideNav.setAttribute('data-mode', isDark ? 'dark' : 'light');

      const lineBg = sideNav.querySelector('.line-bg') as HTMLElement | null;
      const scrollText = sideNav.querySelector('.scroll-text') as HTMLElement | null;
      const scrollIndicator = sideNav.querySelector('.scroll-indicator') as HTMLElement | null;

      if (lineBg) {
        lineBg.style.borderLeftColor = isDark ? 'rgba(255,255,255,0.25)' : '';
      }

      if (scrollText) {
        scrollText.style.color = isDark ? 'rgba(255,255,255,0.5)' : '';
      }

      if (scrollIndicator) {
        scrollIndicator.style.backgroundColor = isDark ? 'rgba(255,255,255,0.25)' : '';
      }
    }

    // Click handlers para navegação suave (div inteiro é clicável)
    navButtons.forEach(el => {
      const handler = (e: Event) => {
        e.preventDefault();
        const targetId = (el as HTMLElement).getAttribute('data-section');
        if (!targetId) return;
        const targetSection = document.getElementById(targetId);
        if (targetSection) {
          const offset = 80;
          const targetPosition = targetSection.getBoundingClientRect().top + window.pageYOffset - offset;
          window.scrollTo({ top: targetPosition, behavior: 'smooth' });
        }
      };
      el.addEventListener('click', handler);
      // Suporte a teclado (Enter / Space)
      el.addEventListener('keydown', (e: Event) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Enter' || ke.key === ' ') handler(e);
      });
    });


  };

  // Inicializa o script no primeiro load e em navegações via ViewTransitions
  document.addEventListener('DOMContentLoaded', initNav);
  document.addEventListener('astro:page-load', initNav);
</script>
